{
	"name": "bounty-ninja",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.5",
	"engines": {
		"node": "22.23.1"
	},
	"overrides": {
		"cookie": "0.7.2",
		"dompurify": "3.4.11",
		"esbuild": "0.28.1",
		"picomatch": "4.0.5",
		"postcss": "8.5.16",
		"yaml": "2.8.3"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"smoke:deployment": "bun run scripts/smoke-deployment.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:bundle": "bun run scripts/check-bundle-size.ts",
		"check:headers": "cmp static/_headers build/_headers && cmp static/_redirects build/_redirects",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run src/tests/unit",
		"test:integration": "vitest run src/tests/integration",
		"test:e2e": "playwright test",
		"test:e2e:services": "bun run scripts/e2e-services.ts",
		"lint": "bun run lint:format && bun run lint:code",
		"lint:format": "prettier --check \"src/**/*.{ts,svelte,css}\" \"scripts/**/*.{ts,js}\" \"static/**/*.{js,json}\" \"*.{js,json,ts}\" \".github/**/*.{yml,yaml}\"",
		"lint:code": "eslint src scripts static/theme-init.js *.config.js *.config.ts --ignore-pattern \"src/tests/**\" --ignore-pattern \"src/lib/components/ui/**\"",
		"format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"scripts/**/*.{ts,js}\" \"static/**/*.{js,json}\" \"*.{js,json,ts}\" \".github/**/*.{yml,yaml}\""
	},
	"type": "module",
	"dependencies": {
		"@cashu/cashu-ts": "3.4.1",
		"@sveltejs/kit": "2.69.2",
		"applesauce-accounts": "5.1.0",
		"applesauce-actions": "5.1.1",
		"applesauce-common": "5.1.0",
		"applesauce-core": "5.1.0",
		"applesauce-loaders": "5.1.0",
		"applesauce-relay": "5.1.0",
		"applesauce-signers": "5.1.0",
		"applesauce-wallet": "5.0.0",
		"clsx": "2.1.1",
		"dompurify": "3.4.11",
		"nostr-idb": "4.0.1",
		"nostr-tools": "2.23.9",
		"rxjs": "7.8.2",
		"svelte": "5.56.4",
		"tailwind-merge": "3.4.0",
		"tw-animate-css": "1.4.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@internationalized/date": "3.11.0",
		"@lucide/svelte": "0.561.0",
		"@playwright/test": "1.58.2",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@tailwindcss/vite": "4.3.2",
		"@types/node": "25.2.3",
		"@vitest/coverage-v8": "4.1.10",
		"bits-ui": "2.15.5",
		"eslint": "10.0.0",
		"eslint-plugin-svelte": "3.15.0",
		"fake-indexeddb": "6.2.5",
		"globals": "17.3.0",
		"jsdom": "28.0.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.4.1",
		"svelte-check": "4.3.6",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.3.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.55.0",
		"vite": "8.1.4",
		"vitest": "4.1.10",
		"wrangler": "4.110.0"
	}
}
